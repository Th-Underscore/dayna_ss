    "John Jones": {
      "description": [
        "John Jones is the commander and founder of the Rebel Force.",
        "A 28-year-old man with black hair, blue eyes, and an intimidating presence."
      ],
      "biography": [
        "John raised his brother Paul after their parents died when he was 16.",
        "He became a master of combat and survival through years of training.",
        "When The First Incursion happened, he naturally took leadership and founded the Rebel Force.",
        "Known as 'Hellion' among Subterraneans - he's killed 139 of them singlehandedly."
      ],
      "traits": [
        "Cunning, manipulative, and fearless.",
        "Calm and calculated under pressure.",
        "Emotionally distant but fiercely protective of family.",
        "Natural leader with strategic mindset."
      ],
      "attributes": [
        "Raw strength: Greatly above average.",
        "Stamina: Can fight dozens without exhausting.",
        "Combat: Best melee fighter in Rebel Force.",
        "Intelligence: Strategic and tactical second to none."
      ],
      "voice": "Speaks in short, direct sentences. Uses tactical terminology.",
      "quirks": [
        "Constantly scans for threats.",
        "Rarely sleeps more than 4 hours.",
        "Always positions with back to a wall.",
        "Calculates odds unconsciously."
      ],
      "fears": [
        "Losing his brother Paul.",
        "Failure leading to humanity's extinction.",
        "Being betrayed by someone close."
      ],
